# Copy to .env and fill in real values.

APP_NAME="ClujHackathon2026 API"
DEBUG=true

# Comma-separated list of allowed frontend origins
# CORS_ORIGINS=["http://localhost:5173","http://127.0.0.1:5173"]

# PostgreSQL connection (driver = asyncpg, so "+asyncpg" and "ssl=require").
DATABASE_URL=postgresql+asyncpg://USER:PASSWORD@HOST:5432/DBNAME?ssl=require

# Secret used to sign JWT access tokens (use a long random string in production).
JWT_SECRET_KEY=replace-with-a-long-random-string-at-least-32-chars

# Frontend URL — must match your Vite dev server (used for Google OAuth redirect).
FRONTEND_URL=http://localhost:5173

# OAuth - Google (https://console.cloud.google.com/)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
