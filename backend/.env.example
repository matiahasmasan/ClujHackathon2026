# Copy to .env and fill in real values.

APP_NAME="ClujHackathon2026 API"
DEBUG=true

# Comma-separated list of allowed frontend origins
# CORS_ORIGINS=["http://localhost:5173","http://127.0.0.1:5173"]

# PostgreSQL connection (driver = asyncpg, so "+asyncpg" and "ssl=require").
DATABASE_URL=postgresql+asyncpg://USER:PASSWORD@HOST:5432/DBNAME?ssl=require

# If seniors/medications have RLS enabled but no policies, dashboard SELECTs return
# zero rows. For local dev, run backend/sql/dev_rls_policies.sql or use a BYPASSRLS role.

# Secret used to sign JWT access tokens (use a long random string in production).
JWT_SECRET_KEY=replace-with-a-long-random-string-at-least-32-chars

# Google Sign-In: the OAuth 2.0 Web Client ID from Google Cloud Console.
# Must be the SAME value the frontend uses (VITE_GOOGLE_CLIENT_ID).
GOOGLE_CLIENT_ID=xxxxxxxxxxxx-xxxxxxxxxxxxxxxxxxxxxxxxxxxx.apps.googleusercontent.com
